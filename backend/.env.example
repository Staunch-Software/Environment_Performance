DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/orb_platform
SECRET_KEY=your-secret-key-min-32-chars-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ANTHROPIC_API_KEY=your-anthropic-api-key
USE_MOCK_EXTRACTION=true
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
# Leave empty on Linux/VM (poppler-utils is on PATH).
# On local Windows set to your poppler bin folder, e.g.
# POPPLER_PATH=C:\poppler\poppler-26.02.0\Library\bin
POPPLER_PATH=
# Comma-separated CORS origins. Default below covers local dev + the VM domain.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://envper.ozellar.com
# Set true ONLY on local machines behind an SSL-inspecting proxy that breaks
# TLS verification. MUST stay false on the VM/production.
DISABLE_SSL_VERIFY=false
